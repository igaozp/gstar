{
  "name": "gstar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "dev:web": "bun --cwd apps/web run dev",
    "dev:api": "bun --cwd apps/api run dev",
    "build:web": "bun --cwd apps/web run build",
    "build:api": "bun --cwd apps/api run build",
    "db:generate": "bun --cwd apps/api run db:generate",
    "db:migrate": "bun --cwd apps/api run db:migrate",
    "db:push": "bun --cwd apps/api run db:push",
    "db:studio": "bun --cwd apps/api run db:studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
