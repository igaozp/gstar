{
  "name": "gstar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "dev:web": "npm run dev --workspace=@gstar/web",
    "dev:api": "npm run dev --workspace=@gstar/api",
    "build:web": "npm run build --workspace=@gstar/web",
    "build:api": "npm run build --workspace=@gstar/api",
    "db:generate": "npm run db:generate --workspace=@gstar/api",
    "db:migrate": "npm run db:migrate --workspace=@gstar/api",
    "db:push": "npm run db:push --workspace=@gstar/api",
    "db:studio": "npm run db:studio --workspace=@gstar/api"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
