---
import Base from '@/layouts/Base.astro'
import { StarCard } from '@/components/stars/StarCard'
import { StarFilters } from '@/components/stars/StarFilters'
import { Pagination } from '@/components/stars/Pagination'
import { api } from '@/lib/api'
import { createTranslator, getRequestLocale } from '@/lib/i18n'

const locale = getRequestLocale(Astro.request)
const t = createTranslator(locale)
const url = Astro.url
const page = Math.max(1, parseInt(url.searchParams.get('page') ?? '1'))
const language = url.searchParams.get('language') ?? undefined
const topic = url.searchParams.get('topic') ?? undefined
const analyzed = (url.searchParams.get('analyzed') as 'true' | 'false') ?? undefined

let result
try {
  result = await api.stars({ page, limit: 24, language, topic, analyzed })
} catch {
  result = { data: [], meta: { page: 1, limit: 24, total: 0, pages: 0 } }
}

// Fetch all to derive language list (limited: get first 200 to extract unique languages)
let allLanguages: string[] = []
try {
  const all = await api.stars({ limit: 100 })
  allLanguages = [...new Set(
    all.data.map((s) => s.language).filter((l): l is string => !!l)
  )].sort()
} catch {}

const { data: stars, meta } = result
---

<Base title={t('page.stars.title')} locale={locale}>
  <div class="space-y-8">
    <section class="grid gap-6 border border-border bg-card/80 p-6 shadow-sm lg:grid-cols-[1fr_auto] lg:items-end lg:p-10">
      <div class="space-y-3">
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-muted-foreground">{t('stars.eyebrow')}</p>
        <h1 class="font-heading text-5xl font-semibold leading-none tracking-tight sm:text-6xl">{t('stars.title')}</h1>
        <p class="max-w-2xl text-sm leading-7 text-muted-foreground">
          {t('stars.description')}
        </p>
      </div>
      <StarFilters client:load languages={allLanguages} locale={locale} />
    </section>

    {stars.length === 0 ? (
      <div class="border border-dashed border-border bg-card/70 p-14 text-center">
        <h2 class="font-heading text-3xl font-semibold">{t('stars.empty.title')}</h2>
        <p class="mt-2 text-sm text-muted-foreground">{t('stars.empty.description')}</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        {stars.map((star) => (
          <StarCard star={star} href={`/stars/${star.id}`} locale={locale} />
        ))}
      </div>
    )}

    <Pagination client:load page={meta.page} pages={meta.pages} total={meta.total} locale={locale} />
  </div>
</Base>
