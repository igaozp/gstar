---
import Base from '@/layouts/Base.astro'
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/card'
import { Badge } from '@/components/ui/badge'
import { Separator } from '@/components/ui/separator'
import { SyncButton } from '@/components/settings/SyncButton'
import { api } from '@/lib/api'

let health
let config

try {
  health = await api.health()
} catch {
  health = null
}

try {
  config = await api.config()
} catch {
  config = null
}

const stars = health?.data?.stars
const lastSync = health?.data?.lastSync
---

<Base title="Settings">
  <div class="mx-auto max-w-6xl space-y-8">
    <section class="border border-border bg-card/80 p-6 shadow-sm lg:p-10">
      <p class="text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-muted-foreground">Control room</p>
      <h1 class="mt-3 font-heading text-5xl font-semibold leading-none tracking-tight sm:text-6xl">Settings</h1>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-muted-foreground">
        Monitor sync health, trigger GitHub ingestion, and verify provider configuration for analysis and embeddings.
      </p>
    </section>

    <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <Card className="border border-border shadow-sm">
      <CardHeader>
        <CardTitle>Status</CardTitle>
      </CardHeader>
      <CardContent class="space-y-4">
        {stars ? (
          <div class="grid grid-cols-2 gap-4">
            <div class="border border-border bg-background p-4">
              <div class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-muted-foreground">Total</div>
              <div class="mt-2 font-heading text-4xl font-semibold">{stars.total.toLocaleString()}</div>
            </div>
            <div class="border border-border bg-background p-4">
              <div class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-muted-foreground">Analyzed</div>
              <div class="mt-2 font-heading text-4xl font-semibold">{stars.analyzed.toLocaleString()}</div>
            </div>
            <div class="border border-border bg-background p-4">
              <div class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-muted-foreground">Pending</div>
              <div class="mt-2 font-heading text-4xl font-semibold">{stars.pending.toLocaleString()}</div>
            </div>
            <div class="border border-border bg-background p-4">
              <div class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-muted-foreground">Embedded</div>
              <div class="mt-2 font-heading text-4xl font-semibold">{stars.embedded.toLocaleString()}</div>
            </div>
          </div>
        ) : (
          <p class="text-sm text-muted-foreground">Could not reach backend.</p>
        )}

        {lastSync && (
          <>
            <Separator />
            <div class="text-sm space-y-1">
              <div class="flex items-center gap-2">
                <span class="text-muted-foreground">Last sync:</span>
                <Badge variant={lastSync.status === 'completed' ? 'default' : lastSync.status === 'failed' ? 'destructive' : 'secondary'}>
                  {lastSync.status}
                </Badge>
                <span class="text-muted-foreground">{lastSync.syncType}</span>
              </div>
              <div class="text-muted-foreground text-xs">
                {new Date(lastSync.startedAt).toLocaleString()} · {lastSync.reposSynced} synced
              </div>
            </div>
          </>
        )}
      </CardContent>
    </Card>

    <Card className="border border-border shadow-sm">
      <CardHeader>
        <CardTitle>Sync</CardTitle>
      </CardHeader>
      <CardContent>
        <p class="mb-5 text-sm leading-7 text-muted-foreground">
          Incremental sync fetches only new stars since the last sync. Full sync re-fetches everything.
        </p>
        <SyncButton client:load />
      </CardContent>
    </Card>
    </div>

    {config && (
      <div class="grid gap-6 lg:grid-cols-2">
        <Card className="border border-border shadow-sm">
          <CardHeader>
            <CardTitle>GitHub</CardTitle>
          </CardHeader>
          <CardContent class="space-y-4 text-sm">
            <div class="flex justify-between border-b border-border pb-3">
              <span class="text-muted-foreground">Username</span>
              <span class="font-mono">{config.data.github.username ?? '—'}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-muted-foreground">Token</span>
              <Badge variant={config.data.github.configured ? 'default' : 'destructive'}>
                {config.data.github.configured ? 'configured' : 'not set'}
              </Badge>
            </div>
          </CardContent>
        </Card>

        <Card className="border border-border shadow-sm">
          <CardHeader>
            <CardTitle>LLM</CardTitle>
          </CardHeader>
          <CardContent class="space-y-4 text-sm">
            <div class="flex justify-between border-b border-border pb-3">
              <span class="text-muted-foreground">Provider</span>
              <span class="font-mono">{config.data.llm.provider}</span>
            </div>
            <div class="flex justify-between border-b border-border pb-3">
              <span class="text-muted-foreground">Chat model</span>
              <span class="font-mono">{config.data.llm.chatModel ?? '—'}</span>
            </div>
            <div class="flex justify-between border-b border-border pb-3">
              <span class="text-muted-foreground">Embedding model</span>
              <span class="font-mono">{config.data.llm.embeddingModel ?? '—'}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-muted-foreground">Dimensions</span>
              <span class="font-mono">{config.data.llm.embeddingDimensions}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-muted-foreground">API key</span>
              <Badge variant={config.data.llm.configured ? 'default' : 'destructive'}>
                {config.data.llm.configured ? 'configured' : 'not set'}
              </Badge>
            </div>
            {config.data.llm.baseUrl && (
              <div class="flex justify-between">
                <span class="text-muted-foreground">Base URL</span>
                <span class="font-mono text-xs">{config.data.llm.baseUrl}</span>
              </div>
            )}
          </CardContent>
        </Card>
      </div>
    )}
  </div>
</Base>
