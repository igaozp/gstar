---
import Base from '@/layouts/Base.astro'
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/card'
import { Badge } from '@/components/ui/badge'
import { Separator } from '@/components/ui/separator'
import { SyncButton } from '@/components/settings/SyncButton'
import { ConfigForm } from '@/components/settings/ConfigForm'
import { api } from '@/lib/api'
import { createTranslator, getRequestLocale, type MessageKey } from '@/lib/i18n'

const locale = getRequestLocale(Astro.request)
const t = createTranslator(locale)

let health
let config

try {
  health = await api.health()
} catch {
  health = null
}

try {
  config = await api.config()
} catch {
  config = null
}

const stars = health?.data?.stars
const lastSync = health?.data?.lastSync
const statusKey: MessageKey = lastSync?.status === 'completed'
  ? 'settings.status.completed'
  : lastSync?.status === 'failed'
    ? 'settings.status.failed'
    : 'settings.status.running'
const syncTypeKey: MessageKey = lastSync?.syncType === 'full' ? 'settings.syncType.full' : 'settings.syncType.incremental'
---

<Base title={t('page.settings.title')} locale={locale}>
  <div class="mx-auto max-w-6xl space-y-8">
    <section class="border border-border bg-card/80 p-6 shadow-sm lg:p-10">
      <p class="text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-muted-foreground">{t('settings.eyebrow')}</p>
      <h1 class="mt-3 font-heading text-5xl font-semibold leading-none tracking-tight sm:text-6xl">{t('settings.title')}</h1>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-muted-foreground">
        {t('settings.description')}
      </p>
    </section>

    <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <Card className="border border-border shadow-sm">
      <CardHeader>
        <CardTitle>{t('settings.status')}</CardTitle>
      </CardHeader>
      <CardContent class="space-y-4">
        {stars ? (
          <div class="grid grid-cols-2 gap-4">
            <div class="border border-border bg-background p-4">
              <div class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-muted-foreground">{t('settings.total')}</div>
              <div class="mt-2 font-heading text-4xl font-semibold">{stars.total.toLocaleString(locale)}</div>
            </div>
            <div class="border border-border bg-background p-4">
              <div class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-muted-foreground">{t('settings.analyzed')}</div>
              <div class="mt-2 font-heading text-4xl font-semibold">{stars.analyzed.toLocaleString(locale)}</div>
            </div>
            <div class="border border-border bg-background p-4">
              <div class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-muted-foreground">{t('settings.pending')}</div>
              <div class="mt-2 font-heading text-4xl font-semibold">{stars.pending.toLocaleString(locale)}</div>
            </div>
            <div class="border border-border bg-background p-4">
              <div class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-muted-foreground">{t('settings.embedded')}</div>
              <div class="mt-2 font-heading text-4xl font-semibold">{stars.embedded.toLocaleString(locale)}</div>
            </div>
          </div>
        ) : (
          <p class="text-sm text-muted-foreground">{t('settings.backendUnavailable')}</p>
        )}

        {lastSync && (
          <>
            <Separator />
            <div class="text-sm space-y-1">
              <div class="flex items-center gap-2">
                <span class="text-muted-foreground">{t('settings.lastSync')}</span>
                <Badge variant={lastSync.status === 'completed' ? 'default' : lastSync.status === 'failed' ? 'destructive' : 'secondary'}>
                  {t(statusKey)}
                </Badge>
                <span class="text-muted-foreground">{t(syncTypeKey)}</span>
              </div>
              <div class="text-muted-foreground text-xs">
                {new Date(lastSync.startedAt).toLocaleString(locale)} · {t('settings.syncedCount', { count: lastSync.reposSynced.toLocaleString(locale) })}
              </div>
            </div>
          </>
        )}
      </CardContent>
    </Card>

    <Card className="border border-border shadow-sm">
      <CardHeader>
        <CardTitle>{t('settings.sync')}</CardTitle>
      </CardHeader>
      <CardContent>
        <p class="mb-5 text-sm leading-7 text-muted-foreground">
          {t('settings.syncDescription')}
        </p>
        <SyncButton client:load locale={locale} />
      </CardContent>
    </Card>
    </div>

    {config && (
      <ConfigForm client:load initialConfig={config.data} locale={locale} />
    )}
  </div>
</Base>
