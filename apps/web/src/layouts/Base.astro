---
import Nav from '@/components/layout/Nav.astro'
import '@/styles/globals.css'

export interface Props {
  title?: string
}

const { title = 'gstar' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — gstar</title>
  </head>
  <body class="theme min-h-screen overflow-x-hidden bg-background font-sans text-foreground antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,oklch(var(--border)/0.55)_1px,transparent_1px),linear-gradient(to_bottom,oklch(var(--border)/0.55)_1px,transparent_1px)] bg-[size:72px_72px] opacity-35"></div>
      <div class="absolute left-1/2 top-0 h-[34rem] w-[34rem] -translate-x-1/2 rounded-full bg-muted/70 blur-3xl"></div>
      <div class="absolute -right-32 top-24 h-80 w-80 rounded-full border border-border/70"></div>
      <div class="absolute -left-24 bottom-10 h-72 w-72 rounded-full border border-border/70"></div>
    </div>
    <Nav />
    <main class="mx-auto w-full max-w-[1480px] px-4 py-8 sm:px-6 lg:px-10 lg:py-12">
      <slot />
    </main>
  </body>
</html>
