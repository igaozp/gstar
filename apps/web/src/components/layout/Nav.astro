---
const navLinks = [
  { href: '/', label: 'Search' },
  { href: '/stars', label: 'Stars' },
  { href: '/settings', label: 'Settings' },
]
const pathname = Astro.url.pathname
---

<header class="sticky top-0 z-50 border-b border-border/80 bg-background/80 backdrop-blur-xl">
  <div class="mx-auto flex h-16 w-full max-w-[1480px] items-center justify-between px-4 sm:px-6 lg:px-10">
    <a href="/" class="group flex items-center gap-3 text-foreground">
      <span class="grid size-9 place-items-center border border-foreground/15 bg-card shadow-sm transition-colors group-hover:bg-foreground group-hover:text-background">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </span>
      <span class="leading-none">
        <span class="block font-heading text-xl font-semibold tracking-widest uppercase">gstar</span>
        <span class="mt-1 hidden text-[0.62rem] font-semibold uppercase tracking-[0.32em] text-muted-foreground sm:block">semantic star atlas</span>
      </span>
    </a>
    <nav class="flex items-center border border-border bg-card/80 p-1 shadow-sm">
      {navLinks.map(({ href, label }) => {
        const active = pathname === href || (href !== '/' && pathname.startsWith(href))
        return (
          <a
            href={href}
            class:list={[
              'px-3 py-2 text-[0.65rem] font-semibold uppercase tracking-[0.2em] transition-colors sm:px-5',
              active
                ? 'bg-foreground text-background'
                : 'text-muted-foreground hover:bg-muted hover:text-foreground',
            ]}
          >
            {label}
          </a>
        )
      })}
    </nav>
  </div>
</header>
