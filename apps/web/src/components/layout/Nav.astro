---
const navLinks = [
  { href: '/', label: 'Search' },
  { href: '/stars', label: 'Stars' },
  { href: '/settings', label: 'Settings' },
]
const pathname = Astro.url.pathname
---

<header class="border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60 sticky top-0 z-50">
  <div class="container flex h-14 items-center gap-6">
    <a href="/" class="flex items-center gap-2 font-semibold text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-yellow-500">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      gstar
    </a>
    <nav class="flex items-center gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-3 py-1.5 rounded-md text-sm transition-colors',
            pathname === href
              ? 'bg-accent text-accent-foreground font-medium'
              : 'text-muted-foreground hover:text-foreground hover:bg-accent/50',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>
