# GitHub Personal Access Token (scopes: read:user, public_repo)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_USERNAME=your_username

# LLM Provider: "openai" | "anthropic" | "openai_compatible"
LLM_PROVIDER=openai
LLM_API_KEY=sk-xxxxxxxxxxxx
LLM_BASE_URL=                          # Leave empty for OpenAI default
LLM_CHAT_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_EMBEDDING_DIMENSIONS=1536

# For Anthropic: Anthropic has no embedding API, configure a separate embedding endpoint
# LLM_EMBEDDING_API_KEY=sk-xxx
# LLM_EMBEDDING_BASE_URL=https://api.openai.com/v1

# For Ollama local usage:
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_CHAT_MODEL=llama3.2
# LLM_EMBEDDING_MODEL=nomic-embed-text
# LLM_EMBEDDING_DIMENSIONS=768

DB_PATH=./data/gstar.db
